# ============================================================
# VARIÁVEIS OBRIGATÓRIAS
# ============================================================

# Chave secreta do Flask (use: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=sua_chave_secreta_aqui

# URI de conexão com o MongoDB
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/nome_do_banco

# ============================================================
# MERCADO PAGO
# ============================================================
# Token de acesso (TEST-xxx para sandbox, APP-xxx para produção)
# Encontre em: https://www.mercadopago.com.br/developers → Credenciais
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret do webhook (configurado no painel do Mercado Pago)
MERCADOPAGO_WEBHOOK_SECRET=seu_webhook_secret

# ============================================================
# URLS DA APLICAÇÃO
# ============================================================
APP_URL=http://localhost:3000
APP_URL_RECOVERY=http://localhost:3000
APP_URL_DOCUMENT_SIGNATURE=http://localhost:3000

# ============================================================
# EMAIL (SMTP)
# ============================================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=seu_email@gmail.com
MAIL_PASSWORD=sua_senha_de_app
MAIL_DEFAULT_SENDER=seu_email@gmail.com
TEMPLATE_URL=http://localhost:5000/

# ============================================================
# REDIS (opcional — usa memória se não configurado)
# ============================================================
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true
REDIS_VEHICLE_TTL=3600
RATELIMIT_STORAGE_URL=redis://localhost:6379/0

# ============================================================
# FIREBASE (opcional — para armazenamento de arquivos)
# ============================================================
FIREBASE_BUCKET_NAME=seu-projeto.appspot.com

# ============================================================
# WHATSAPP CHATBOT (opcional)
# ============================================================
WHATSAPP_TOKEN=seu_token_whatsapp
WHATSAPP_VERIFY_TOKEN=seu_token_verificacao
PHONE_NUMBER_ID=seu_phone_number_id
WHATSAPP_APP_SECRET=seu_app_secret
WHATSAPP_API_URL=https://graph.facebook.com/v17.0
PASSWORD_CHATBOT_SALT=seu_salt_aqui
SESSION_TIMEOUT_MINUTES=30

# ============================================================
# OUTROS
# ============================================================
PORT=5000
CORS_ORIGINS=*
API_BASE_URL=http://localhost:5000
